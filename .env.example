# Finnhub — get a free key at https://finnhub.io (no credit card required)
FINNHUB_API_KEY=your_key_here

# TimescaleDB (host port 5433 to avoid clashing with a local Postgres on 5432)
DATABASE_URL=postgres://watchtower:watchtower@localhost:5433/watchtower?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092

# Server
SERVER_PORT=8080

# Dev-only debug endpoints (anomaly simulation). Keep false in production.
ENABLE_DEV_ENDPOINTS=false
